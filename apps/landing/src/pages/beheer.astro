---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/siab/Header.astro';
import Footer from '../components/siab/Footer.astro';
import FaqSection from '../components/siab/FaqSection.astro';
import { site } from '../content/site';

const pageTitle = 'Beheer login';
const pageDescription = 'Log in op de beheeromgeving van je Site in a Box website.';
---

<BaseLayout title={pageTitle} description={pageDescription} noindex>
  <Header />
  <main>
    <section class="siab-beheer-hero mt-180 lg-mt-80" aria-labelledby="beheer-heading">
      <div class="container lg">
        <div class="row align-items-center gx-xxl-5">
          <div class="col-lg-6">
            <div class="title-eleven mb-25 lg-mb-10">
              <h1 id="beheer-heading">Log in op je beheeromgeving.</h1>
            </div>
            <p class="fs-22 text-dark opacity-75 m0">
              Vul het domein van je website in. We sturen je naar de juiste beheeromgeving, bijvoorbeeld admin.jouwdomein.nl.
            </p>

            <ul class="siab-beheer-perks" aria-label="Beheeromgeving mogelijkheden">
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                Je eigen tenant-login
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                Domein blijft leidend
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                Veilig gescheiden beheer
              </li>
            </ul>
          </div>

          <div class="col-lg-6 mt-40 mt-lg-0">
            <section class="siab-beheer-card" aria-label="Login domein kiezen">
              <p class="siab-beheer-eyebrow">Beheer login</p>
              <h2>Waar staat je website?</h2>
              <form id="tenant-login-form" class="siab-beheer-form" novalidate>
                <label for="tenant-domain">Website domein</label>
                <div class="siab-beheer-control">
                  <input
                    id="tenant-domain"
                    name="domain"
                    type="text"
                    inputmode="url"
                    autocomplete="url"
                    placeholder="jouwdomein.nl"
                    aria-describedby="tenant-domain-help tenant-domain-error"
                    required
                  />
                  <button type="submit" class="btn-eighteen">Inloggen</button>
                </div>
                <p id="tenant-domain-help" class="siab-beheer-help">
                  Gebruik het domein van je website. Als je admin.jouwdomein.nl invult, gebruiken we die direct.
                </p>
                <p id="tenant-domain-error" class="siab-beheer-error" role="alert" hidden>
                  Vul een geldig domein in, bijvoorbeeld ami-care.nl.
                </p>
              </form>

              <div class="siab-beheer-admin">
                <span>Site in a Box beheerder?</span>
                <a href={site.links.platformAdminLogin}>Open platform login</a>
              </div>
            </section>
          </div>
        </div>
      </div>
    </section>

    <FaqSection />
  </main>
  <Footer />

  <script is:inline>
    (function () {
      var form = document.getElementById('tenant-login-form');
      var input = document.getElementById('tenant-domain');
      var error = document.getElementById('tenant-domain-error');
      if (!form || !input || !error) return;

      function normalizeDomain(value) {
        var raw = String(value || '').trim().toLowerCase();
        raw = raw.replace(/^https?:\/\//, '').replace(/^\/+/, '');
        raw = raw.split('/')[0].split('?')[0].split('#')[0];
        raw = raw.replace(/:\d+$/, '');
        raw = raw.replace(/^www\./, '');
        return raw;
      }

      function isValidDomain(domain) {
        return /^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.)+[a-z]{2,63}$/.test(domain);
      }

      form.addEventListener('submit', function (event) {
        event.preventDefault();
        error.hidden = true;

        var domain = normalizeDomain(input.value);
        var host = domain.startsWith('admin.') ? domain : 'admin.' + domain;

        if (!isValidDomain(domain) || !isValidDomain(host)) {
          error.hidden = false;
          input.setAttribute('aria-invalid', 'true');
          input.focus();
          return;
        }

        input.removeAttribute('aria-invalid');
        window.location.assign('https://' + host + '/login');
      });
    })();
  </script>
</BaseLayout>

<style>
  .siab-beheer-hero {
    padding-bottom: 80px;
  }

  .siab-beheer-card {
    background: var(--siab-bg-surface);
    border: 2px solid var(--siab-border);
    border-radius: 0;
    box-shadow: 6px 6px var(--siab-shadow-color);
    padding: clamp(28px, 4vw, 48px);
  }

  .siab-beheer-eyebrow {
    font-family: 'Chivo', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--siab-text-muted);
    margin: 0 0 12px;
  }

  .siab-beheer-card h2 {
    color: var(--siab-text);
    font-size: 56px;
    line-height: 1;
    margin: 0 0 28px;
  }

  .siab-beheer-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .siab-beheer-form label {
    font-family: 'Chivo', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: var(--siab-text);
  }

  .siab-beheer-control {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 14px;
    align-items: stretch;
  }

  .siab-beheer-control input {
    width: 100%;
    min-height: 56px;
    border: 2px solid var(--siab-border);
    border-radius: 0;
    background: var(--siab-bg-page);
    color: var(--siab-text);
    padding: 0 18px;
    font-family: 'Chivo', sans-serif;
    font-size: 17px;
    font-weight: 500;
  }

  .siab-beheer-control input::placeholder {
    color: var(--siab-text-muted);
    opacity: 0.75;
  }

  .siab-beheer-control input[aria-invalid='true'] {
    border-color: #f96a00;
  }

  .siab-beheer-control .btn-eighteen {
    border: 2px solid var(--siab-border);
    min-height: 56px;
    white-space: nowrap;
  }

  .siab-beheer-help,
  .siab-beheer-error {
    font-family: 'Chivo', sans-serif;
    font-size: 15px;
    line-height: 1.5;
    margin: 0;
  }

  .siab-beheer-help {
    color: var(--siab-text-muted);
  }

  .siab-beheer-error {
    color: #c44800;
    font-weight: 700;
  }

  .siab-beheer-admin {
    border-top: 1px solid color-mix(in srgb, var(--siab-border) 18%, transparent);
    margin-top: 28px;
    padding-top: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    align-items: center;
    font-family: 'Chivo', sans-serif;
    font-size: 15px;
    color: var(--siab-text-muted);
  }

  .siab-beheer-admin a {
    color: var(--siab-text);
    font-weight: 700;
    text-decoration: underline 2px solid var(--siab-border);
    text-underline-offset: 4px;
  }

  .siab-beheer-perks {
    list-style: none;
    margin: 30px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 12px 26px;
  }

  .siab-beheer-perks li {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Chivo', sans-serif;
    font-weight: 600;
    font-size: 15px;
    line-height: 1.3;
    color: var(--siab-text);
  }

  .siab-beheer-perks svg {
    color: #000;
    flex-shrink: 0;
    background: #f5e900;
    border: 2px solid var(--siab-border);
    border-radius: 50%;
    width: 26px;
    height: 26px;
    padding: 3px;
  }

  @media (max-width: 767px) {
    .siab-beheer-card h2 {
      font-size: 34px;
      line-height: 1.08;
    }

    .siab-beheer-control {
      grid-template-columns: 1fr;
    }

    .siab-beheer-control .btn-eighteen {
      width: 100%;
    }
  }
</style>
